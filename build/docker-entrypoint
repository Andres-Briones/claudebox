#!/bin/bash
set -euo pipefail

# Ensure PATH includes user's local bin directory
# This will be substituted with actual username during build
export PATH="/home/DOCKERUSER/.local/bin:$PATH"

# Also set PATH for runuser commands
export RUNUSER_PATH="/home/DOCKERUSER/.local/bin:$PATH"

ENABLE_SUDO=false
DISABLE_FIREWALL=false
SHELL_MODE=false
new_args=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --enable-sudo) ENABLE_SUDO=true; shift ;;
        --disable-firewall) DISABLE_FIREWALL=true; shift ;;
        shell) SHELL_MODE=true; shift ;;
        *) new_args+=("$1"); shift ;;
    esac
done
if [[ ${#new_args[@]} -gt 0 ]]; then
    set -- "${new_args[@]}"
else
    set --
fi
export DISABLE_FIREWALL

# Debug output (check environment variable)
if [[ "${VERBOSE:-false}" == "true" ]]; then
    echo "DEBUG: Arguments: $@" >&2
    echo "DEBUG: Number of args: $#" >&2
    echo "DEBUG: ENABLE_SUDO=$ENABLE_SUDO" >&2
    echo "DEBUG: DISABLE_FIREWALL=$DISABLE_FIREWALL" >&2
    echo "DEBUG: SHELL_MODE=$SHELL_MODE" >&2
fi

if [ -f /home/DOCKERUSER/init-firewall ]; then
    /home/DOCKERUSER/init-firewall || true
fi

# Handle sudo access based on --enable-sudo flag
# Note: DOCKERUSER user already has sudoers entry from Dockerfile
if [ "$ENABLE_SUDO" != "true" ]; then
    # Remove sudo access if --enable-sudo wasn't passed
    rm -f /etc/sudoers.d/DOCKERUSER
fi

# Python venv management with flag-based system
if [ -n "${CLAUDEBOX_PROJECT_NAME:-}" ]; then
    CLAUDEBOX_DIR="/home/DOCKERUSER/.claudebox"
    CONFIG_FILE="$CLAUDEBOX_DIR/profiles.ini"
    VENV_DIR="$CLAUDEBOX_DIR/.venv"
    VENV_FLAG="$CLAUDEBOX_DIR/.venv_flag"
    PYDEV_FLAG="$CLAUDEBOX_DIR/.pydev_flag"

    # Check if we need to set up the core Python environment
    if command -v uv >/dev/null 2>&1; then
        # Check if both venv folder and .venv_flag exist
        if [ -d "$VENV_DIR" ] && [ -f "$VENV_FLAG" ]; then
            # Already set up, just ensure activation in shell rc files
            for shell_rc in /home/DOCKERUSER/.zshrc /home/DOCKERUSER/.bashrc; do
                # Add .local/bin to PATH if not already there
                if ! grep -q "PATH.*\.local/bin" "$shell_rc"; then
                    echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$shell_rc"
                fi
                # Add venv activation if not already there
                if ! grep -q "source $VENV_DIR/bin/activate" "$shell_rc"; then
                    echo "if [ -f $VENV_DIR/bin/activate ]; then source $VENV_DIR/bin/activate; fi" >> "$shell_rc"
                fi
            done
        else
            # Check if venv exists but flag is missing (incomplete previous run)
            if [ -d "$VENV_DIR" ] && [ ! -f "$VENV_FLAG" ]; then
                # Try to acquire lock for recreating corrupted venv
                if runuser -u DOCKERUSER -- mkdir -p "$(dirname "$VENV_FLAG")" && runuser -u DOCKERUSER -- mkdir "$VENV_FLAG.lock" 2>/dev/null; then
                    # We got the lock, recreate venv with --clear
                    PATH="/home/DOCKERUSER/.local/bin:$PATH" runuser -u DOCKERUSER -- uv venv --python-preference managed --clear "$VENV_DIR" || true
                    
                    # Remove lock and create flag to indicate completion
                    runuser -u DOCKERUSER -- rmdir "$VENV_FLAG.lock"
                    runuser -u DOCKERUSER -- touch "$VENV_FLAG"
                else
                    # Someone else is fixing it, wait for completion
                    wait_count=0
                    while [ ! -f "$VENV_FLAG" ] && [ $wait_count -lt 60 ]; do
                        sleep 0.5
                        ((wait_count++)) || true
                    done
                    
                    if [ ! -f "$VENV_FLAG" ]; then
                        echo "Warning: Timeout waiting for venv recreation" >&2
                    fi
                fi
            else
                # Normal case - try to create new venv
                if runuser -u DOCKERUSER -- mkdir -p "$(dirname "$VENV_FLAG")" && runuser -u DOCKERUSER -- mkdir "$VENV_FLAG.lock" 2>/dev/null; then
                    # We got the lock, create venv if needed
                    if [ ! -d "$VENV_DIR" ]; then
                        PATH="/home/DOCKERUSER/.local/bin:$PATH" runuser -u DOCKERUSER -- uv venv --python-preference managed "$VENV_DIR" || true
                    fi
                    
                    # Remove lock and create flag to indicate completion
                    runuser -u DOCKERUSER -- rmdir "$VENV_FLAG.lock"
                    runuser -u DOCKERUSER -- touch "$VENV_FLAG"
                else
                    # Someone else is creating it, wait for completion flag
                    wait_count=0
                    while [ ! -f "$VENV_FLAG" ] && [ $wait_count -lt 60 ]; do
                        sleep 0.5
                        ((wait_count++)) || true
                    done
                    
                    # If still no flag after timeout, something went wrong
                    if [ ! -f "$VENV_FLAG" ]; then
                        echo "Warning: Timeout waiting for venv creation" >&2
                    fi
                fi
            fi
            
            # Add activation to shell rc files only if venv was successfully created
            if [ -f "$VENV_FLAG" ] && [ -d "$VENV_DIR" ]; then
                for shell_rc in /home/DOCKERUSER/.zshrc /home/DOCKERUSER/.bashrc; do
                    # Add .local/bin to PATH if not already there
                    if ! grep -q "PATH.*\.local/bin" "$shell_rc"; then
                        echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$shell_rc"
                    fi
                    # Add venv activation if not already there
                    if ! grep -q "source $VENV_DIR/bin/activate" "$shell_rc"; then
                        echo "if [ -f $VENV_DIR/bin/activate ]; then source $VENV_DIR/bin/activate; fi" >> "$shell_rc"
                    fi
                done
            fi
        fi

        # Check if Python profile is added and deploy Python dev tools if needed
        if [ -f "$CONFIG_FILE" ] && grep -qE 'python|ml|datascience' "$CONFIG_FILE"; then
            if [ ! -f "$PYDEV_FLAG" ] && [ -f "$VENV_FLAG" ] && [ -d "$VENV_DIR" ]; then
                # Deploy Python dev tools based on profile
                python_packages=""
                
                # Base Python profile packages
                if grep -q 'python' "$CONFIG_FILE"; then
                    python_packages="ipython black mypy pylint pytest ruff poetry pipenv"
                fi
                
                # ML profile packages
                if grep -q 'ml' "$CONFIG_FILE"; then
                    python_packages="$python_packages torch transformers scikit-learn numpy pandas matplotlib"
                fi
                
                # Data science profile packages
                if grep -q 'datascience' "$CONFIG_FILE"; then
                    python_packages="$python_packages jupyter notebook jupyterlab numpy pandas scipy matplotlib seaborn scikit-learn statsmodels plotly"
                fi
                
                # Remove duplicates and install
                if [ -n "$python_packages" ]; then
                    PATH="/home/DOCKERUSER/.local/bin:$PATH" runuser -u DOCKERUSER -- bash -c "
                        source $VENV_DIR/bin/activate
                        uv pip install $python_packages
                    " || true
                    
                    # Create .pydev_flag to indicate Python dev tools are deployed
                    if [ $? -eq 0 ]; then
                        runuser -u DOCKERUSER -- touch "$PYDEV_FLAG"
                    fi
                fi
            fi
        fi
    fi
fi

# Generate tooling.md if profiles have changed
if [ -n "${CLAUDEBOX_PROJECT_NAME:-}" ]; then
    PROFILES_INI="/home/DOCKERUSER/.claudebox/profiles.ini"
    TOOLING_FILE="/home/DOCKERUSER/.claudebox/tooling.md"
    CHECKSUM_FILE="/home/DOCKERUSER/.claudebox/.tooling_checksum"
    
    if [ -f "$PROFILES_INI" ]; then
        # Calculate current checksum of profiles.ini
        CURRENT_CHECKSUM=$(sha256sum "$PROFILES_INI" | cut -d' ' -f1)
        
        # Check if we need to regenerate
        NEED_REGENERATE=false
        if [ ! -f "$TOOLING_FILE" ]; then
            # No tooling file exists yet
            NEED_REGENERATE=true
        elif [ ! -f "$CHECKSUM_FILE" ]; then
            # No checksum file exists
            NEED_REGENERATE=true
        else
            # Compare checksums - use if statement to avoid set -e issues
            STORED_CHECKSUM=""
            if [ -f "$CHECKSUM_FILE" ]; then
                STORED_CHECKSUM=$(cat "$CHECKSUM_FILE")
            fi
            if [ "$CURRENT_CHECKSUM" != "$STORED_CHECKSUM" ]; then
                NEED_REGENERATE=true
            fi
        fi
        
        if [ "$NEED_REGENERATE" = "true" ]; then
            # Generate the tooling file as the docker user
            if runuser -u DOCKERUSER -- generate-tools-readme >/dev/null 2>&1; then
                # Store the checksum as the docker user
                runuser -u DOCKERUSER -- bash -c "echo '$CURRENT_CHECKSUM' > '$CHECKSUM_FILE'"
            fi
        fi
    fi
fi

cd /home/DOCKERUSER

# Merge host ~/.claude into the slot's ~/.claude (runs in both shell and
# claude modes). Host ~/.claude is mounted read-only at /tmp/host-claude-home
# by docker.sh.
#
# Two cases per top-level dir (e.g. skills/, agents/):
#   - slot doesn't have the dir → symlink the whole host dir into the slot.
#   - slot already has it (seed-populated by sync_claude_seed_files) → merge
#     per-child. User wins on name collisions: replace the slot's seed copy
#     with a symlink to the host child. This lets fork-shipped defaults
#     coexist with user customs, with the user able to override defaults by
#     using the same name.
# Stale host-symlinks (host source removed) are cleaned so the next seed
# sync can re-populate the seed default.
if [ -d "/tmp/host-claude-home" ]; then
    for item in /tmp/host-claude-home/*/; do
        # Skip if glob didn't match anything
        if [ ! -d "$item" ]; then
            continue
        fi

        dir_name=$(basename "$item")

        # Skip known system directories
        case "$dir_name" in
            projects|sessions|commands|statsig|todos|keys|mcp)
                continue
                ;;
        esac

        # Skip hidden directories
        case "$dir_name" in
            .*)
                continue
                ;;
        esac

        host_src="/tmp/host-claude-home/$dir_name"
        target="/home/DOCKERUSER/.claude/$dir_name"

        if [ ! -e "$target" ]; then
            # Slot has nothing here — link the whole host dir.
            runuser -u DOCKERUSER -- ln -s "$host_src" "$target"
            if [ "${VERBOSE:-false}" = "true" ]; then
                printf 'Linked host dir: %s\n' "$dir_name" >&2
            fi
            continue
        fi

        # If $target is already a top-level symlink to $host_src, a prior
        # launch already linked the whole dir — idempotent, skip the merge.
        # Without this guard, the per-child loop below would resolve through
        # the symlink and try to rm files on the host's read-only bind mount.
        if [ -L "$target" ]; then
            link_target=$(readlink "$target" 2>/dev/null || true)
            if [ "$link_target" = "$host_src" ]; then
                continue
            fi
        fi

        # Slot already has this dir as a real dir (from seed). Merge per-child.
        for child in "$host_src"/* "$host_src"/.*; do
            if [ ! -e "$child" ]; then
                continue
            fi
            child_name=$(basename "$child")
            case "$child_name" in
                .|..) continue ;;
            esac
            target_child="$target/$child_name"
            if [ -L "$target_child" ]; then
                # Already a host-symlink (idempotent across relaunches).
                continue
            fi
            if [ -e "$target_child" ]; then
                # Slot has a seed copy — user wins, replace with host symlink.
                runuser -u DOCKERUSER -- rm -rf "$target_child"
            fi
            runuser -u DOCKERUSER -- ln -s "$host_src/$child_name" "$target_child"
            if [ "${VERBOSE:-false}" = "true" ]; then
                printf 'Override host: %s/%s\n' "$dir_name" "$child_name" >&2
            fi
        done

        # Clean dangling host-symlinks in the slot dir (host child was
        # removed). Without cleanup the broken symlink would shadow the seed
        # default forever; removing it lets the next seed sync re-populate.
        for slot_child in "$target"/* "$target"/.*; do
            if [ ! -L "$slot_child" ]; then
                continue
            fi
            slot_child_name=$(basename "$slot_child")
            case "$slot_child_name" in
                .|..) continue ;;
            esac
            link_target=$(readlink "$slot_child" 2>/dev/null || true)
            case "$link_target" in
                /tmp/host-claude-home/*)
                    if [ ! -e "$slot_child" ]; then
                        runuser -u DOCKERUSER -- rm -f "$slot_child"
                        if [ "${VERBOSE:-false}" = "true" ]; then
                            printf 'Cleaned dangling host-symlink: %s/%s\n' "$dir_name" "$slot_child_name" >&2
                        fi
                    fi
                    ;;
            esac
        done
    done

    # Merge host CLAUDE.md into slot CLAUDE.md so the container sees both
    # claudebox-sourced (seed) and host-sourced (user) instructions. The seed
    # is already in the slot at this point (sync_claude_seed_files ran on the
    # host pre-launch); we append a Claude Code @import directive so host
    # edits are picked up live without re-syncing. Marker keeps the append
    # idempotent across relaunches; if the seed gets re-synced (newer mtime)
    # the marker disappears and we re-append on the next start.
    if [ -L "/tmp/host-claude-home/CLAUDE.md" ] && [ ! -e "/tmp/host-claude-home/CLAUDE.md" ]; then
        # Dangling symlink: host ~/.claude/CLAUDE.md points outside ~/.claude,
        # so the target isn't visible from inside the container. The [ -f ]
        # test below would silently skip, and an @import directive pointing
        # at the broken link wouldn't load either — warn explicitly so the
        # user can fix it on the host.
        host_claude_md_target=$(readlink "/tmp/host-claude-home/CLAUDE.md" 2>/dev/null || true)
        printf 'claudebox: warning: host ~/.claude/CLAUDE.md is a symlink to %s, which is not mounted in the container. Host CLAUDE.md will not be merged into the slot. Fix by replacing the symlink with a regular file, or by moving the target under ~/.claude/.\n' "$host_claude_md_target" >&2
    elif [ -f "/tmp/host-claude-home/CLAUDE.md" ]; then
        if [ -f "/home/DOCKERUSER/.claude/CLAUDE.md" ]; then
            if ! grep -qF 'claudebox:host-claude-md-import' "/home/DOCKERUSER/.claude/CLAUDE.md"; then
                runuser -u DOCKERUSER -- bash -c 'printf "\n\n<!-- claudebox:host-claude-md-import -->\n@/tmp/host-claude-home/CLAUDE.md\n" >> "/home/DOCKERUSER/.claude/CLAUDE.md"'
                if [ "${VERBOSE:-false}" = "true" ]; then
                    printf 'Appended host CLAUDE.md @import to slot CLAUDE.md\n' >&2
                fi
            fi
        else
            runuser -u DOCKERUSER -- ln -s "/tmp/host-claude-home/CLAUDE.md" "/home/DOCKERUSER/.claude/CLAUDE.md"
        fi
    fi
fi

# GSD profile activation/deactivation. The staging dir at host ~/.claude/gsd/
# (mounted read-only at /tmp/host-claude-home/gsd/) is inert until the slot's
# profiles.ini lists `gsd` — at that point per-file symlinks wire its
# commands/agents/hooks into the slot's live dirs and settings.gsd.json is
# jq-merged into the slot's settings.json.
#
# Deactivation is symmetric: when `gsd` leaves the profile chain, sweep the
# symlinks and restore settings.json from the pre-merge backup written on
# first activation. Without this sweep, prior activation state (per-file
# symlinks) persists in the slot's ~/.claude/ across rebuilds, so /gsd:*
# commands keep working even after `claudebox remove gsd`.
SLOT_HOME="/home/DOCKERUSER/.claude"
GSD_HOST_STAGING="/tmp/host-claude-home/gsd"
GSD_LOCAL_STAGING="$SLOT_HOME/.gsd-staging"
GSD_STAGING="$GSD_HOST_STAGING"
GSD_PROFILES_INI="/home/DOCKERUSER/.claudebox/profiles.ini"
GSD_BACKUP="$SLOT_HOME/.gsd-settings-backup.json"
GSD_MARKER='"_gsd_managed":true'
GSD_ACTIVE=false
if [ -f "$GSD_PROFILES_INI" ]; then
    # Extract names from the [profiles] section (one per line, no [).
    if awk '
        /^\[profiles\]$/ { in_section=1; next }
        /^\[/             { in_section=0 }
        in_section && /^gsd$/ { print; exit }
    ' "$GSD_PROFILES_INI" | grep -q '^gsd$'; then
        if [ -d "$GSD_HOST_STAGING" ]; then
            GSD_ACTIVE=true
        fi
    fi
fi

if [ "$GSD_ACTIVE" = "true" ]; then
    if [ "${VERBOSE:-false}" = "true" ]; then
        printf 'GSD profile active — activating staging payload\n' >&2
    fi

    # Copy the host-mounted staging into a slot-owned dir before any
    # symlink/jq-merge step references it. Under rootless docker the host
    # mount appears owned by an unmapped UID inside the container, so
    # DOCKERUSER cannot read it (host ~/.claude is mode 700 by Claude
    # Code's own design). Root in the container can read the mount in
    # either rootful or rootless mode, so cp -a as root + chown to
    # DOCKERUSER decouples runtime read access from the host UID mapping.
    # Refresh on every launch so host-side `gsd-install.sh --update`
    # propagates on the next claudebox start.
    rm -rf "$GSD_LOCAL_STAGING"
    mkdir -p "$GSD_LOCAL_STAGING"
    cp -a "$GSD_HOST_STAGING/." "$GSD_LOCAL_STAGING/"
    chown -R DOCKERUSER:DOCKERUSER "$GSD_LOCAL_STAGING"
    GSD_STAGING="$GSD_LOCAL_STAGING"

    # Per-file symlinks for commands/gsd, agents, hooks. Symlink targets
    # point at the slot-local staging copy populated above.
    for sub in commands/gsd agents hooks; do
        gsd_src_dir="$GSD_STAGING/$sub"
        gsd_dst_dir="$SLOT_HOME/$sub"
        if [ ! -d "$gsd_src_dir" ]; then
            continue
        fi
        # If $gsd_dst_dir exists but isn't a real directory (dangling
        # symlink from the legacy GSD opt-in code, regular file, etc.),
        # remove it so mkdir -p succeeds. Without this, mkdir -p fails
        # with "File exists" on the stale state.
        gsd_need_clean=false
        if [ -L "$gsd_dst_dir" ]; then
            gsd_need_clean=true
        elif [ -e "$gsd_dst_dir" ]; then
            if [ ! -d "$gsd_dst_dir" ]; then
                gsd_need_clean=true
            fi
        fi
        if [ "$gsd_need_clean" = "true" ]; then
            runuser -u DOCKERUSER -- rm -rf "$gsd_dst_dir"
        fi
        runuser -u DOCKERUSER -- mkdir -p "$gsd_dst_dir"
        for gsd_f in "$gsd_src_dir"/*; do
            if [ ! -e "$gsd_f" ]; then
                continue
            fi
            gsd_target="$gsd_dst_dir/$(basename "$gsd_f")"
            if [ -L "$gsd_target" ]; then
                continue
            fi
            if [ -e "$gsd_target" ]; then
                runuser -u DOCKERUSER -- rm -rf "$gsd_target"
            fi
            runuser -u DOCKERUSER -- ln -s "$gsd_f" "$gsd_target"
        done
    done

    # Workflows: command stubs @-reference ~/.claude/get-shit-done/workflows/.
    # Create the get-shit-done dir as a real dir in the slot, then symlink
    # workflows under it (avoids exposing host bin/lib if upstream ships them).
    if [ -d "$GSD_STAGING/workflows" ]; then
        # The slot may have a stale ~/.claude/get-shit-done symlink from the
        # pre-staging install (host-merge loop auto-linked the whole host
        # dir; new install doesn't ship that path). Same cleanup as above.
        gsd_gsd_dir="$SLOT_HOME/get-shit-done"
        gsd_need_clean=false
        if [ -L "$gsd_gsd_dir" ]; then
            gsd_need_clean=true
        elif [ -e "$gsd_gsd_dir" ]; then
            if [ ! -d "$gsd_gsd_dir" ]; then
                gsd_need_clean=true
            fi
        fi
        if [ "$gsd_need_clean" = "true" ]; then
            runuser -u DOCKERUSER -- rm -rf "$gsd_gsd_dir"
        fi
        runuser -u DOCKERUSER -- mkdir -p "$gsd_gsd_dir"
        gsd_wf_target="$gsd_gsd_dir/workflows"
        if [ ! -L "$gsd_wf_target" ]; then
            if [ -e "$gsd_wf_target" ]; then
                runuser -u DOCKERUSER -- rm -rf "$gsd_wf_target"
            fi
            runuser -u DOCKERUSER -- ln -s "$GSD_STAGING/workflows" "$gsd_wf_target"
        fi
    fi

    # jq-merge the settings fragment into the slot's settings.json. Backup
    # the pre-merge state once (when the marker isn't present yet) so
    # deactivation can restore. Add a marker so we can detect already-merged
    # state across re-runs and skip re-backing-up.
    if [ -f "$GSD_STAGING/settings.gsd.json" ] && command -v jq >/dev/null 2>&1; then
        if [ ! -f "$SLOT_HOME/settings.json" ]; then
            runuser -u DOCKERUSER -- bash -c 'echo "{}" > "$HOME/.claude/settings.json"'
        fi
        # Marker check via jq, not grep — jq pretty-prints with a space after
        # the colon (`"_gsd_managed": true`), so a literal grep for the
        # no-space form misses every time and we'd re-backup the merged
        # state on every relaunch (corrupting the backup).
        gsd_marker_present=false
        if [ "$(jq -r '._gsd_managed // false' "$SLOT_HOME/settings.json" 2>/dev/null)" = "true" ]; then
            gsd_marker_present=true
        fi
        if [ "$gsd_marker_present" = "false" ]; then
            runuser -u DOCKERUSER -- cp "$SLOT_HOME/settings.json" "$GSD_BACKUP"
        fi
        runuser -u DOCKERUSER -- bash -c '
            set -e
            settings="$HOME/.claude/settings.json"
            fragment="$1"
            tmp=$(mktemp)
            jq -s ".[0] * .[1] * {\"_gsd_managed\": true}" "$settings" "$fragment" > "$tmp"
            mv "$tmp" "$settings"
        ' _ "$GSD_STAGING/settings.gsd.json"
    fi
else
    # Deactivation: sweep slot symlinks pointing into the GSD staging dir
    # and restore settings.json from the pre-merge backup if one exists.
    # Runs whenever `gsd` is not in the profile chain — covers both fresh
    # never-activated slots (no-op) and slots that had GSD removed.
    if [ "${VERBOSE:-false}" = "true" ]; then
        printf 'GSD profile inactive — sweeping prior activation state\n' >&2
    fi
    # Match symlinks from both the legacy host-mount staging path (slots
    # activated by older entrypoint versions) and the slot-local staging
    # path used by the current rootless-safe activation.
    for sub in commands/gsd agents hooks; do
        gsd_sweep_dir="$SLOT_HOME/$sub"
        if [ ! -d "$gsd_sweep_dir" ]; then
            continue
        fi
        for gsd_f in "$gsd_sweep_dir"/*; do
            if [ ! -L "$gsd_f" ]; then
                continue
            fi
            gsd_link_target=$(readlink "$gsd_f" 2>/dev/null || true)
            case "$gsd_link_target" in
                "$GSD_HOST_STAGING"/*|"$GSD_LOCAL_STAGING"/*)
                    runuser -u DOCKERUSER -- rm -f "$gsd_f"
                    ;;
            esac
        done
        # Drop empty dirs we created on activation.
        if [ -d "$gsd_sweep_dir" ] && [ -z "$(ls -A "$gsd_sweep_dir" 2>/dev/null)" ]; then
            runuser -u DOCKERUSER -- rmdir "$gsd_sweep_dir" 2>/dev/null || true
        fi
    done

    # Workflows symlink + parent dir.
    gsd_sweep_wf="$SLOT_HOME/get-shit-done/workflows"
    if [ -L "$gsd_sweep_wf" ]; then
        gsd_link_target=$(readlink "$gsd_sweep_wf" 2>/dev/null || true)
        case "$gsd_link_target" in
            "$GSD_HOST_STAGING"/*|"$GSD_LOCAL_STAGING"/*)
                runuser -u DOCKERUSER -- rm -f "$gsd_sweep_wf"
                ;;
        esac
    fi
    if [ -d "$SLOT_HOME/get-shit-done" ] && [ -z "$(ls -A "$SLOT_HOME/get-shit-done" 2>/dev/null)" ]; then
        runuser -u DOCKERUSER -- rmdir "$SLOT_HOME/get-shit-done" 2>/dev/null || true
    fi

    # Slot-local staging copy (current activation format).
    if [ -e "$GSD_LOCAL_STAGING" ]; then
        rm -rf "$GSD_LOCAL_STAGING"
    fi

    # Restore settings.json:
    #   1. If a pre-merge backup exists AND looks clean (no GSD fragment in
    #      it), restore from it — preserves any user customizations made to
    #      settings.json before activation. A backup that itself contains
    #      the GSD fragment is corrupt (caused by the v1 marker-check bug
    #      that re-backed-up the merged state); discard it.
    #   2. Then unconditionally strip GSD-introduced keys as a safety net.
    #      Safe because the seed baseline ships no statusLine/hooks; any of
    #      those keys still present after step 1 came from the fragment.
    if [ -f "$GSD_BACKUP" ] && command -v jq >/dev/null 2>&1; then
        gsd_backup_clean=true
        if [ "$(jq -r '._gsd_managed // false' "$GSD_BACKUP" 2>/dev/null)" = "true" ]; then
            gsd_backup_clean=false
        fi
        if [ "$gsd_backup_clean" = "true" ]; then
            runuser -u DOCKERUSER -- mv "$GSD_BACKUP" "$SLOT_HOME/settings.json"
        else
            runuser -u DOCKERUSER -- rm -f "$GSD_BACKUP"
        fi
    fi

    if [ -f "$SLOT_HOME/settings.json" ] && command -v jq >/dev/null 2>&1; then
        gsd_needs_strip=false
        if grep -qF '/hooks/gsd-' "$SLOT_HOME/settings.json"; then
            gsd_needs_strip=true
        elif [ "$(jq -r '._gsd_managed // false' "$SLOT_HOME/settings.json" 2>/dev/null)" = "true" ]; then
            gsd_needs_strip=true
        fi
        if [ "$gsd_needs_strip" = "true" ]; then
            runuser -u DOCKERUSER -- bash -c '
                set -e
                s="$HOME/.claude/settings.json"
                tmp=$(mktemp)
                jq "del(._gsd_managed, .statusLine, .hooks)" "$s" > "$tmp"
                mv "$tmp" "$s"
            '
        fi
    fi
fi

# Install a 'claude' shell wrapper (idempotent) that warns when claude is
# launched from a non-/workspace dir. Memory writes from a non-/workspace
# cwd land in ~/.claude/projects/<derived-slug>/memory/, bypassing the
# cross-slot shared-memory bind mount which is hardcoded to -workspace in
# lib/docker.sh.
for shell_rc in /home/DOCKERUSER/.zshrc /home/DOCKERUSER/.bashrc; do
    if [ ! -f "$shell_rc" ]; then
        continue
    fi
    if grep -q 'claudebox-pwd-check' "$shell_rc"; then
        continue
    fi
    cat >> "$shell_rc" << 'PWDCHECK'

# claudebox-pwd-check: warn when claude is launched from a non-/workspace dir
# (memory writes would bypass the cross-slot shared-memory bind mount).
claude() {
    if [ "$PWD" != "/workspace" ]; then
        local slug
        slug=$(printf '%s' "$PWD" | sed 's|/|-|g')
        printf '\033[33m[claudebox] launching claude from %s — memory writes will go to ~/.claude/projects/%s/memory/ and bypass the shared-memory bind mount. cd /workspace first if you need cross-slot persistence.\033[0m\n' "$PWD" "$slug" >&2
    fi
    command claude "$@"
}
PWDCHECK
done

# No need for complex exit handlers - just copy after claude exits

if [[ "${SHELL_MODE:-false}" == "true" ]]; then
    # Use runuser to avoid PTY signal handling issues
    if [[ "${CLAUDEBOX_WRAP_TMUX:-false}" == "true" ]]; then
        # For tmux, create an init script that shows logo then starts shell
        cat > /tmp/tmux-init.sh << 'EOF'
#!/bin/bash
export PATH="/home/DOCKERUSER/.local/bin:$PATH"
if [ -d /home/DOCKERUSER/.claudebox/.venv ]; then
    export PATH="/home/DOCKERUSER/.claudebox/.venv/bin:$PATH"
    export VIRTUAL_ENV="/home/DOCKERUSER/.claudebox/.venv"
fi
source /home/DOCKERUSER/.claudebox/common.sh 2>/dev/null
logo_header 2>/dev/null
exec /bin/zsh
EOF
        chmod +x /tmp/tmux-init.sh
        sed -i "s|DOCKERUSER|$DOCKERUSER|g" /tmp/tmux-init.sh
        exec runuser -u DOCKERUSER -- bash -c "source /home/DOCKERUSER/.nvm/nvm.sh && cd /workspace && exec tmux new-session /tmp/tmux-init.sh"
    else
        # For non-tmux, show logo before starting shell
        exec runuser -u DOCKERUSER -- bash -c "source /home/DOCKERUSER/.nvm/nvm.sh && export PATH=\"/home/DOCKERUSER/.local/bin:\$PATH\" && [ -d /home/DOCKERUSER/.claudebox/.venv ] && export PATH=\"/home/DOCKERUSER/.claudebox/.venv/bin:\$PATH\" && export VIRTUAL_ENV=\"/home/DOCKERUSER/.claudebox/.venv\"; cd /workspace && source /home/DOCKERUSER/.claudebox/common.sh 2>/dev/null && logo_header 2>/dev/null; exec /bin/zsh"
    fi
else
    # Claude mode - handle wrapper logic directly here
    if [[ "${1:-}" == "update" ]]; then
        # Special update handling - pass all arguments
        shift  # Remove "update" from arguments
        exec runuser -u DOCKERUSER -- bash -c '
            export NVM_DIR="$HOME/.nvm"
            if [[ -s "$NVM_DIR/nvm.sh" ]]; then
                \. "$NVM_DIR/nvm.sh"
                nvm use default >/dev/null 2>&1 || {
                    echo "Warning: Failed to activate default Node version" >&2
                }
            else
                echo "Warning: NVM not found at $NVM_DIR" >&2
            fi
            
            cd /workspace
            echo "Running update command..."
            
            # Check for stale update lock (older than 5 minutes)
            lock_file="$HOME/.DOCKERUSER/.update.lock"
            if [[ -f "$lock_file" ]]; then
                lock_age=$(( $(date +%s) - $(stat -f %m "$lock_file" 2>/dev/null || stat -c %Y "$lock_file" 2>/dev/null || echo 0) ))
                if [[ $lock_age -gt 300 ]]; then
                    rm -f "$lock_file"
                fi
            fi
            
            # Capture the output of claude update to check if already up to date
            update_output=$(claude update 2>&1)
            echo "$update_output"
            
            # Only run version check if an actual update occurred
            if echo "$update_output" | grep -q "Successfully updated\|Installing update"; then
                echo "Verifying update..."
                claude --version
            fi
        '
    else
        # Regular DOCKERUSER execution
        exec runuser -u DOCKERUSER -- bash -c '
            export NVM_DIR="$HOME/.nvm"
            if [[ -s "$NVM_DIR/nvm.sh" ]]; then
                \. "$NVM_DIR/nvm.sh"
                nvm use default >/dev/null 2>&1 || {
                    echo "Warning: Failed to activate default Node version" >&2
                }
            else
                echo "Warning: NVM not found at $NVM_DIR" >&2
            fi
            
            # tooling.md generation is handled in root section above
            
            # Ensure uv is in PATH
            export PATH="$HOME/.local/bin:$PATH"
            
            # Activate Python venv if it exists
            if [ -f "$HOME/.claudebox/.venv/bin/activate" ]; then
                source "$HOME/.claudebox/.venv/bin/activate"
            fi
            
            # Create symlink from ~/.claude/commands to ~/.claudebox/commands
            # The ~/.claudebox folder is mounted from the host
            if [ -d "$HOME/.claudebox/commands" ]; then
                if [ ! -e "$HOME/.claude/commands" ]; then
                    ln -s "$HOME/.claudebox/commands" "$HOME/.claude/commands"
                fi
            fi

            # GSD opt-in: merge host ~/.claude/commands/gsd/ into the slot
            # commands dir as one namespaced subdir. Narrow exception to the
            # commands skip-list at the top of this script: top-level command
            # files stay isolated, but a clearly-namespaced subdir is safe
            # and lets `claudebox add gsd` ship slash commands too.
            if [ -d "/tmp/host-claude-home/commands/gsd" ]; then
                if [ ! -e "$HOME/.claude/commands" ]; then
                    mkdir -p "$HOME/.claude/commands"
                fi
                if [ ! -e "$HOME/.claude/commands/gsd" ]; then
                    ln -s /tmp/host-claude-home/commands/gsd "$HOME/.claude/commands/gsd"
                fi
            fi

            cd /workspace
            
            # Prepare MCP configuration arguments for native --mcp-config support
            mcp_config_args=()
            
            # Add user MCP config if available (lower priority)
            if [[ -f "/tmp/user-mcp-config.json" ]]; then
                mcp_config_args+=(--mcp-config /tmp/user-mcp-config.json)
                if [[ "${VERBOSE:-false}" == "true" ]]; then
                    printf "Loading user MCP servers\n" >&2
                fi
            fi
            
            # Add project MCP config if available (higher priority - processed last)
            if [[ -f "/tmp/project-mcp-config.json" ]]; then
                mcp_config_args+=(--mcp-config /tmp/project-mcp-config.json)
                if [[ "${VERBOSE:-false}" == "true" ]]; then
                    printf "Loading project MCP servers\n" >&2
                fi
            fi
            
            # Check if .claude/projects exists and filter out -c/--continue if not
            if [[ ! -d "$HOME/.claude/projects" ]]; then
                # Filter out -c and --continue flags
                filtered_args=()
                skip_next=false
                for arg in "$@"; do
                    if [[ "$skip_next" == "true" ]]; then
                        skip_next=false
                        continue
                    fi
                    
                    case "$arg" in
                        -c|--continue)
                            # Skip this flag
                            ;;
                        *)
                            filtered_args+=("$arg")
                            ;;
                    esac
                done
                
                # Update positional parameters
                set -- "${filtered_args[@]}"
            fi
            
            # If no arguments and stdin is a terminal, run claude in interactive mode
            if [[ "${CLAUDEBOX_WRAP_TMUX:-false}" == "true" ]]; then
                if [[ $# -eq 0 ]] && [[ -t 0 ]]; then
                    tmux new-session claude "${mcp_config_args[@]}"
                else
                    tmux new-session claude "${mcp_config_args[@]}" "$@"
                fi
            else
                if [[ $# -eq 0 ]] && [[ -t 0 ]]; then
                    # No arguments - just run claude with MCP configs
                    claude "${mcp_config_args[@]}"
                else
                    # Has arguments - pass them through with MCP configs
                    claude "${mcp_config_args[@]}" "$@"
                fi
            fi
            
            # After claude exits, copy .claude.json if it was created
            if [[ -f "$HOME/.claude.json" ]] && [[ ! -f "$HOME/.claudebox/${CLAUDEBOX_SLOT_NAME}/.claude.json" ]]; then
                cp "$HOME/.claude.json" "$HOME/.claudebox/${CLAUDEBOX_SLOT_NAME}/.claude.json"
            fi
        ' -- "$@"
    fi
fi
